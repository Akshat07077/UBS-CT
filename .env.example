# Copy to .env and fill in real values (never commit .env)

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# At least 32 random characters
SESSION_SECRET="change-me-to-a-long-random-secret-32chars"

NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=917974451501
NEXT_PUBLIC_CONTACT_EMAIL=rindorecar@gmail.com

# Cloudinary — required for real car photo uploads
# https://cloudinary.com/console → Dashboard
# Use these three only. Do NOT set CLOUDINARY_URL to placeholder text like <your_api_key>.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Booking: sandbox = confirm without Stripe (default when Stripe keys are empty)
BOOKING_SANDBOX=true
